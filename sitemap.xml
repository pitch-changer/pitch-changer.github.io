---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {% for locale_code in site.locales %}
    <url>
      <loc>{{ site.data.locales[locale_code].site.path | absolute_url }}</loc>
      {% for alternate_code in site.locales %}
        <xhtml:link rel="alternate" hreflang="{{ site.data.locales[alternate_code].site.lang }}" href="{{ site.data.locales[alternate_code].site.path | absolute_url }}" />
      {% endfor %}
      <xhtml:link rel="alternate" hreflang="x-default" href="{{ '/' | absolute_url }}" />
    </url>
  {% endfor %}
</urlset>
